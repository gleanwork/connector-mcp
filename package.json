{
  "name": "@gleanwork/connector-mcp",
  "version": "0.1.0",
  "description": "MCP server for AI-assisted Glean connector development",
  "type": "module",
  "bin": {
    "connector-mcp": "./bin/connector-mcp.js"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:mcp": "npm run build && playwright test",
    "test:mcp:ui": "npm run build && playwright test --ui",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "csv-parse": "^5.5.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@gleanwork/mcp-server-tester": "^0.12.0",
    "@playwright/test": "^1.58.2",
    "@types/node": "^22.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=18"
  }
}
